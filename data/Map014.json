            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "小聽村......這名字聽起來就很耳熟。" ] },
            { "code": 401, "indent": 0, "parameters": [ "好吧，村長，" ] },
            { "code": 401, "indent": 0, "parameters": [ "坦白說，我是受到卡車召喚......" ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "不，我是被卡車撞過來的。" ] },
            { "code": 401, "indent": 0, "parameters": [ "我想要回去原本的世界。" ] },
            { "code": 101, "indent": 0, "parameters": [ "People1", 6, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]村長：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "回去？年輕人，受到異世界召喚的人，" ] },
            { "code": 401, "indent": 0, "parameters": [ "通常都要完成神聖的使命才能回去。" ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "(吐槽) 神聖的使命？" ] },
            { "code": 401, "indent": 0, "parameters": [ "打倒魔王嗎？還是拯救公主？" ] },
            { "code": 401, "indent": 0, "parameters": [ "這劇本也太老套了吧！" ] },
            { "code": 101, "indent": 0, "parameters": [ "People1", 6, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]村長：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "沒那麼複雜。你需要前往『聽語之巔』的神殿，" ] },
            { "code": 401, "indent": 0, "parameters": [ "尋找大祭司。" ] },
            { "code": 401, "indent": 0, "parameters": [ "只有她知道回去的方法。" ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "聽語之巔......大祭司......" ] },
            { "code": 401, "indent": 0, "parameters": [ "為什麼這一切聽起來都跟我的專業有關係？" ] },
            { "code": 101, "indent": 0, "parameters": [ "People1", 6, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]村長：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "門外剛好有前往『聽語之巔』的神殿飛船..." ] },
            { "code": 401, "indent": 0, "parameters": [ "如果你快一點可能還來得及..." ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "等等，村長！那艘船長什麼樣子？" ] },
            { "code": 401, "indent": 0, "parameters": [ "該不會是木頭做的帆船但在天上飛吧？" ] },
            { "code": 401, "indent": 0, "parameters": [ "那種東西真的安全嗎？" ] },
            { "code": 101, "indent": 0, "parameters": [ "People1", 6, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]村長：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "放心吧，那是我們這裡最快的交通工具。" ] },
            { "code": 401, "indent": 0, "parameters": [ "不過，那艘船的引擎聲非常吵，" ] },
            { "code": 401, "indent": 0, "parameters": [ "你最好先做好心理準備，免得下船時耳朵嗡嗡叫。" ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "(吐槽) 又是霧又是噪音，" ] },
            { "code": 401, "indent": 0, "parameters": [ "這個世界對耳朵真的很不友善耶！" ] },
            { "code": 401, "indent": 0, "parameters": [ "我才剛被卡車撞完，又要挑戰耳膜極限嗎？" ] },
            { "code": 101, "indent": 0, "parameters": [ "People1", 6, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]村長：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "(慈祥地笑) 這就是試煉的一部分。" ] },
            { "code": 401, "indent": 0, "parameters": [ "既然你帶著亞大人的身份來到這裡，" ] },
            { "code": 401, "indent": 0, "parameters": [ "這點小困難一定難不倒你的。" ] },
            { "code": 401, "indent": 0, "parameters": [ "對了，大祭司那個人性格很硬，要是他問你什麼，" ] },
            { "code": 401, "indent": 0, "parameters": [ "你就老實回答你是來修復『聽力石』的就好。" ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "修復石頭？我以為我是來拯救世界的勇者，" ] },
            { "code": 401, "indent": 0, "parameters": [ "結果居然是去當維修工嗎？這方向也太偏了吧！" ] },
            { "code": 101, "indent": 0, "parameters": [ "People1", 6, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]村長：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "呵呵，快去吧！別讓大祭司等太久，" ] },
            { "code": 401, "indent": 0, "parameters": [ "她手上的地圖可是不等人的。" ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "好啦好啦，我知道了。雖然搞不清楚狀況，" ] },
            { "code": 401, "indent": 0, "parameters": [ "為了能回家睡我的床，我就去看看飛船多厲害。" ] },
            { "code": 101, "indent": 0, "parameters": [ "Actor1", 0, 0, 2 ] },
            { "code": 401, "indent": 0, "parameters": [ "\\C[2]主角：\\C[0]" ] },
            { "code": 401, "indent": 0, "parameters": [ "村長大人，謝謝你的收留，我出發啦！ 8~8~6~" ] },
